@namespace CreditInTimeFront.WebApp.Components

<MudChip T="string"
         Class="sb-chip"
         Color="@Color"
         Variant="Variant.Filled"
         Size="@Size"
         Ripple="false">
    @Text
</MudChip>

@code {
    [Parameter] public string Text { get; set; } = "";
    [Parameter] public Color Color { get; set; } = Color.Default;
    [Parameter] public Size Size { get; set; } = Size.Small;
}
