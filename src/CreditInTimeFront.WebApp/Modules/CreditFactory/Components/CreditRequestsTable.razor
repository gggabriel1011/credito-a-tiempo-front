@namespace CreditInTimeFront.WebApp.Modules.CreditFactory.Components
@using MudBlazor
@using CreditInTimeFront.WebApp.Modules.CreditFactory.ViewModels

<DataTable T="CreditRequestViewModel"
           Title="Solicitudes por Aprobar"
           TitleIcon="@Icons.Material.Outlined.PendingActions"
           Items="@Requests"
           Filters="@_filters"
           FilterPredicate="@FilterRequest">

    <ColumnDefs>

        <TemplateColumn T="CreditRequestViewModel" Title="Expediente" HeaderStyle="min-width:120px">
            <CellTemplate>
                <span class="cft-badge">@context.Item.CaseNumber</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="CreditRequestViewModel" Title="Cliente / ID" HeaderStyle="min-width:180px">
            <CellTemplate>
                <p class="cft-client-name @(context.Item.IsCompany ? "cft-company" : "")">@context.Item.ClientName</p>
                <p class="cft-client-id">@context.Item.Identification</p>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="CreditRequestViewModel" Title="Producto" HeaderStyle="min-width:140px">
            <CellTemplate>
                <span class="cft-product">@context.Item.Product</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="CreditRequestViewModel" Title="Monto"
                        HeaderClass="dt-col--right"
                        HeaderStyle="min-width:120px"
                        CellStyle="text-align:right">
            <CellTemplate>
                <span class="cft-amount">RD$ @context.Item.Amount.ToString("N0")</span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="CreditRequestViewModel" Title="Progreso"
                        HeaderClass="dt-col--center"
                        HeaderStyle="min-width:100px"
                        CellStyle="text-align:center">
            <CellTemplate>
                <div class="cft-progress-wrap">
                    <div class="cft-progress-track">
                        <div class="cft-progress-fill cft-fill--@GetProgressColor(context.Item.Progress)"
                             style="width: @(context.Item.Progress)%"></div>
                    </div>
                    <span class="cft-progress-pct cft-pct--@GetProgressColor(context.Item.Progress)">
                        @(context.Item.Progress)%
                    </span>
                </div>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="CreditRequestViewModel" Title="Estado"
                        HeaderClass="dt-col--center"
                        HeaderStyle="min-width:110px"
                        CellStyle="text-align:center">
            <CellTemplate>
                <span class="cft-status-badge cft-status--@context.Item.Status.ToString().ToLower()">
                    @context.Item.Status.ToLabel()
                </span>
            </CellTemplate>
        </TemplateColumn>

        <TemplateColumn T="CreditRequestViewModel" Title="Acciones"
                        HeaderClass="dt-col--center"
                        HeaderStyle="min-width:110px"
                        CellStyle="text-align:center">
            <CellTemplate>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Outlined.Print"
                           Class="cft-print-btn"
                           OnClick="() => OnPrintRequest.InvokeAsync(context.Item)">
                    Imprimir
                </MudButton>
            </CellTemplate>
        </TemplateColumn>

    </ColumnDefs>

</DataTable>
