@page "/credit-factory"
@namespace CreditInTimeFront.WebApp.Modules.CreditFactory.Pages
@using MudBlazor
@using CreditInTimeFront.WebApp.Modules.CreditFactory.Components

<!-- Header -->
<PageHeader Title="Fábrica de Crédito "
            TitleAccent="- Panel de Aprobaciones"
            Subtitle="Gestión y Análisis de Solicitudes de Préstamo" />

<!-- KPI Cards -->
<MudGrid Spacing="3" Class="mb-4">
    @foreach (var card in _kpiCards)
    {
        <MudItem xs="12" sm="6" lg="3">
            <MetricCard Icon="@card.Icon"
                        Label="@card.Label"
                        Value="@card.Value"
                        BadgeText="@card.Detail"
                        BadgeVariant="@card.BadgeVariant" />
        </MudItem>
    }
</MudGrid>

<!-- Requests table — filtering and pagination handled internally by DataTable -->
<ErrorBoundary>
    <ChildContent>
        <CreditRequestsTable Requests="@_state.Requests" OnPrintRequest="HandlePrintRequest" />
    </ChildContent>
    <ErrorContent Context="ex">
        <MudAlert Severity="Severity.Error" Class="mb-4">
            Error renderizando la tabla: @ex.Message
        </MudAlert>
    </ErrorContent>
</ErrorBoundary>

<!-- Documents modal -->
<DocumentsModal IsOpen="@_modalOpen"
                Request="@_selectedRequest"
                OnClose="CloseModal"
                OnOpenReport="OpenReport" />
