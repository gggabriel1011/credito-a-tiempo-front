@namespace CreditInTimeFront.WebApp.Modules.CRM.Components
@using MudBlazor
@using CreditInTimeFront.WebApp.Modules.CRM.ViewModels

<DataTable T="InteraccionViewModel"
           Title="Interacciones Recientes"
           TitleIcon="@Icons.Material.Outlined.People"
           Items="@Interacciones"
           Filters="@_filters"
           FilterPredicate="@FilterInteraccion">

    <HeaderActions>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Outlined.PersonAdd"
                   Class="crm-t-nuevo-btn"
                   OnClick="() => OnNuevoCliente.InvokeAsync()">
            Nuevo Cliente
        </MudButton>
    </HeaderActions>

    <ColumnDefs>
        <HierarchyColumn T="InteraccionViewModel" HeaderStyle="width: 40px;" />
        <PropertyColumn T="InteraccionViewModel" TProperty="string" Property="x => x.Identificacion"
                        Title="Identificación" HeaderStyle="width: 120px;" />
        <TemplateColumn T="InteraccionViewModel" Title="Nombre Completo" HeaderStyle="min-width: 140px;">
            <CellTemplate>
                <MudText Typo="Typo.body2"
                         Class="@("crm-t-client-name " + (context.Item.ClienteNombre.Contains(',') || context.Item.ClienteNombre.EndsWith("SA") || context.Item.ClienteNombre.EndsWith("SRL") || context.Item.ClienteNombre.EndsWith("SAS") ? "crm-t-company" : ""))">
                    @context.Item.ClienteNombre
                </MudText>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn T="InteraccionViewModel" TProperty="string" Property="x => x.TipoSolicitud"
                        Title="Tipo Solicitud" HeaderStyle="width: 100px;" />
        <TemplateColumn T="InteraccionViewModel" Title="Tipo Contacto" HeaderStyle="width: 80px;">
            <CellTemplate>@context.Item.TipoContacto.ToLabel()</CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="InteraccionViewModel" Title="Fecha Creación" HeaderStyle="width: 72px;">
            <CellTemplate>@context.Item.FechaCreacion.ToString("dd/MM/yyyy")</CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="InteraccionViewModel" Title="Fecha Inicio" HeaderStyle="width: 68px;">
            <CellTemplate>@(context.Item.FechaInicio?.ToString("dd/MM/yyyy") ?? "—")</CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="InteraccionViewModel" Title="Fecha Estimada" HeaderStyle="width: 72px;">
            <CellTemplate>@(context.Item.FechaEstimada?.ToString("dd/MM/yyyy") ?? "—")</CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="InteraccionViewModel" Title="Fecha Realizado" HeaderStyle="width: 72px;">
            <CellTemplate>@(context.Item.FechaRealizado?.ToString("dd/MM/yyyy") ?? "—")</CellTemplate>
        </TemplateColumn>
        <PropertyColumn T="InteraccionViewModel" TProperty="string" Property="x => x.Sucursal"
                        Title="Sucursal" HeaderStyle="min-width: 90px;" />
        <PropertyColumn T="InteraccionViewModel" TProperty="string" Property="x => x.Departamento"
                        Title="Departamento" HeaderStyle="width: 110px;" />
        <TemplateColumn T="InteraccionViewModel" Title="Estado" HeaderStyle="width: 96px;" HeaderClass="dt-col--center" CellStyle="text-align:center">
            <CellTemplate>
                <span class="crm-t-status-badge crm-t-status--@context.Item.Estado.ToString().ToLower()">
                    @context.Item.Estado.ToLabel()
                </span>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn T="InteraccionViewModel" Title="Acciones" HeaderStyle="width: 72px;">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Outlined.Visibility"
                               Size="Size.Small"
                               Color="Color.Primary"
                               Href="@($"/crm/detalle/{context.Item.ClienteId}")" />
            </CellTemplate>
        </TemplateColumn>
    </ColumnDefs>

    <RowDetails Context="rowCtx">
        <div class="crm-t-detail">
            @if (rowCtx.Item.Seguimientos.Count > 0)
            {
                <div class="crm-t-sub-wrap">
                    <MudText Typo="Typo.caption" Class="crm-t-sub-title">Seguimientos</MudText>
                    <MudTable T="SeguimientoViewModel"
                              Items="@rowCtx.Item.Seguimientos"
                              Elevation="0"
                              Dense="true"
                              Class="crm-t-sub-table">
                        <HeaderContent>
                            <MudTh Style="width:130px">Tipo Acción</MudTh>
                            <MudTh Style="width:140px">Tipo Respuesta</MudTh>
                            <MudTh Style="width:90px">Estado</MudTh>
                            <MudTh Style="width:170px">Resultado</MudTh>
                            <MudTh Style="width:130px">Usuario Atención</MudTh>
                            <MudTh Style="width:140px">Departamento</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="seg">
                            <MudTd DataLabel="Tipo Acción">@seg.TipoAccion</MudTd>
                            <MudTd DataLabel="Tipo Respuesta">@seg.TipoRespuesta</MudTd>
                            <MudTd DataLabel="Estado">@seg.Estado</MudTd>
                            <MudTd DataLabel="Resultado">@seg.Resultado</MudTd>
                            <MudTd DataLabel="Usuario Atención">@seg.UsuarioAtencion</MudTd>
                            <MudTd DataLabel="Departamento">@seg.Departamento</MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            }
            else
            {
                <div class="crm-t-sub-wrap crm-t-sub-empty">
                    <span>Sin seguimientos registrados</span>
                </div>
            }
        </div>
    </RowDetails>

</DataTable>
