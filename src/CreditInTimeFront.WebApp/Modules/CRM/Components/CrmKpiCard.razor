<MudCard Elevation="1" Class="crm-kpi-card">
    <MudCardContent>
        <div class="crm-kpi-top">
            <MudIcon Icon="@Icon" Class="crm-kpi-icon" />
            @if (!string.IsNullOrEmpty(BadgeText))
            {
                <span class="crm-kpi-badge crm-kpi-badge--@BadgeVariant">@BadgeText</span>
            }
        </div>
        <p class="crm-kpi-label">@Label</p>
        <p class="crm-kpi-value @(ValueClass ?? "")">@Value</p>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public string Icon      { get; set; } = "";
    [Parameter] public string Label     { get; set; } = "";
    [Parameter] public string Value     { get; set; } = "";
    [Parameter] public string BadgeText { get; set; } = "";

    /// <summary>primary | warning | info | muted</summary>
    [Parameter] public string BadgeVariant { get; set; } = "muted";

    [Parameter] public string? ValueClass { get; set; }
}
