@page "/crm"
@namespace CreditInTimeFront.WebApp.Modules.CRM.Pages
@using MudBlazor
@using CreditInTimeFront.WebApp.Modules.CRM.Components
@using CreditInTimeFront.WebApp.Modules.CRM.State

<!-- Header -->
<PageHeader Title="CRM "
            TitleAccent="- Gestión de Clientes"
            Subtitle="Seguimiento de Interacciones y Cartera de Clientes" />

<!-- KPI Cards -->
<MudGrid Spacing="3" Class="mb-4">
    @foreach (var card in _kpiCards)
    {
        <MudItem xs="12" sm="6" lg="3">
            <MetricCard Icon="@card.Icon"
                        Label="@card.Label"
                        Value="@card.Value"
                        BadgeText="@card.Detail"
                        BadgeVariant="@card.BadgeVariant" />
        </MudItem>
    }
</MudGrid>

<!-- Charts Row -->
<MudGrid Spacing="3" Class="mb-4">

    <!-- Line Chart: Adquisición por Mes -->
    <MudItem xs="12" md="8">
        <ChartCard Title="Adquisición por Mes" Height="100%" CardClass="crm-line-chart">
            <ChildContent>
                <MudChart T="double"
                          ChartType="ChartType.Line"
                          ChartSeries="@_lineChartSeries"
                          ChartLabels="@CrmState.Meses"
                          Width="100%"
                          Height="260px"
                          ChartOptions="@_lineChartOptions"
                          MatchBoundsToSize="true" />
            </ChildContent>
        </ChartCard>
    </MudItem>

    <!-- Donut Chart: Segmentación de Cartera -->
    <MudItem xs="12" md="4">
        <ChartCard Title="Segmentación de Cartera" Height="100%" CardClass="chart-card--pie">
            <ChildContent>
                <MudChart T="double"
                          ChartType="ChartType.Donut"
                          ChartSeries="@_donutSeries"
                          ChartLabels="@CrmState.SegmentacionLabels"
                          Width="100%"
                          Height="220px"
                          ChartOptions="@_donutChartOptions">
                    <CustomGraphics>
                        <text x="50%" y="50%"
                              dominant-baseline="middle"
                              text-anchor="middle"
                              style="font-size: 1rem; font-weight: 700; fill: var(--text-body);">
                            100%
                        </text>
                    </CustomGraphics>
                </MudChart>
            </ChildContent>
            <Footer>
                <div class="crm-donut-legend">
                    @for (int i = 0; i < _donutLabels.Length; i++)
                    {
                        var idx   = i;
                        var color = _donutPalette[idx % _donutPalette.Length];
                        <div class="crm-legend-row">
                            <div class="crm-legend-left">
                                <span class="crm-legend-dot" style="background: @color"></span>
                                <span class="crm-legend-label">@_donutLabels[idx]</span>
                            </div>
                            <span class="crm-legend-pct">@CrmState.SegmentacionCartera[idx]%</span>
                        </div>
                    }
                </div>
            </Footer>
        </ChartCard>
    </MudItem>

</MudGrid>

<!-- Interactions Table -->
<InteraccionesTable Interacciones="@_state.Interacciones"
                    OnNuevoCliente="HandleNuevoCliente" />
