@inherits LayoutComponentBase
@using MudBlazor
@using CreditInTimeFront.WebApp.Shared.Themes

<MudThemeProvider Theme="BancoAgricolaTheme.GetTheme()" @bind-IsDarkMode="_isDarkMode" />

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="app-shell">

    <MudDrawer Open="true"
               Elevation="1"
               Variant="DrawerVariant.Persistent"
               Class="app-shell-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="padding-top: 0;" Class="app-shell-content">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>
