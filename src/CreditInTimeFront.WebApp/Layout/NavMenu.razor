@namespace CreditInTimeFront.WebApp.Layout
@using MudBlazor

<!-- Logo -->
<div class="nav-header">
    <img src="images/logo-banco-agricola.jpg" alt="Banco Agrícola" class="nav-logo" />
</div>

<!-- User Info -->
<div class="nav-user">
    <MudAvatar Color="Color.Primary" Size="Size.Medium">@_userInitials</MudAvatar>
    <div>
        <MudText Typo="Typo.body2" Class="nav-user-role">@_userRole</MudText>
        <MudText Typo="Typo.caption" Class="nav-user-location">@_userLocation</MudText>
    </div>
</div>

<!-- Navigation -->
<MudNavMenu Class="nav-menu">
    @foreach (var item in _navItems)
    {
        <MudNavLink href="@item.Href" Match="@item.Match" Icon="@item.Icon">
            @item.Label
        </MudNavLink>
    }
</MudNavMenu>
